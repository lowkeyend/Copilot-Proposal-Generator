# ============================================================
# Proposal Copilot — Backend configuration
# Copy this file to `.env` and fill in the values.
# Every setting has a localhost-friendly default; only
# OPENROUTER_API_KEY is strictly required for generation.
# ============================================================

# ---- LLM (OpenRouter) ----
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default model used when the UI does not specify one.
DEFAULT_MODEL=deepseek/deepseek-chat
# Optional attribution headers (recommended by OpenRouter).
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=Proposal Copilot

# ---- Vector DB (Qdrant Cloud) ----
# Production uses one active cloud collection only: proposal_knowledge_base_v3.
# Set QDRANT_URL and QDRANT_API_KEY from your Qdrant Cloud cluster.
QDRANT_PATH=
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=proposal_knowledge_base_v3

# ---- Embeddings ----
# qdrant = Qdrant Cloud Inference. This avoids loading sentence-transformers in the backend.
EMBEDDING_PROVIDER=qdrant
# Must match the vectors stored in the selected Qdrant collection.
# For Qdrant Cloud Inference, use a model available in your cluster's Inference tab.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Required when EMBEDDING_PROVIDER=jina or openai.
EMBEDDING_API_KEY=
EMBEDDING_API_BASE_URL=https://api.jina.ai/v1
# bge models expect this query prefix for retrieval. Ignored by hosted providers.
EMBEDDING_QUERY_PREFIX=Represent this sentence for searching relevant passages:

# ---- Storage (local-first; swap for Supabase later) ----
STORAGE_BACKEND=local
STORAGE_DIR=../storage
GENERATED_DIR=../generated
TEMPLATES_DIR=../templates
ASSETS_DIR=../assets

# ---- Server / CORS ----
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Allow any Vercel deployment for the frontend app.
CORS_ORIGIN_REGEX=https://.*\\.vercel\\.app$
