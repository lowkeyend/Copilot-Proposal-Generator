# ============================================================
# Proposal Copilot — Backend configuration
# Copy this file to `.env` and fill in the values.
# Every setting has a localhost-friendly default; only
# OPENROUTER_API_KEY is strictly required for generation.
# ============================================================

# ---- LLM (OpenRouter) ----
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default model used when the UI does not specify one.
DEFAULT_MODEL=deepseek/deepseek-chat
# Optional attribution headers (recommended by OpenRouter).
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=Proposal Copilot

# ---- Vector DB (Qdrant) ----
# Local mode: leave QDRANT_URL empty and point QDRANT_PATH at the
# on-disk DB produced by Notebook 1.
# Cloud mode: set QDRANT_URL (+ QDRANT_API_KEY) and QDRANT_PATH is ignored.
QDRANT_PATH=../qdrant_local_db
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=proposal_knowledge_base

# ---- Embeddings ----
# Must match the model used during ingestion (Notebook 1).
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# bge models expect this query prefix for retrieval.
EMBEDDING_QUERY_PREFIX=Represent this sentence for searching relevant passages:

# ---- Storage (local-first; swap for Supabase later) ----
STORAGE_BACKEND=local
STORAGE_DIR=../storage
GENERATED_DIR=../generated
TEMPLATES_DIR=../templates
ASSETS_DIR=../assets

# ---- Server / CORS ----
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Allow any Vercel deployment for the frontend app.
CORS_ORIGIN_REGEX=https://.*\\.vercel\\.app$
